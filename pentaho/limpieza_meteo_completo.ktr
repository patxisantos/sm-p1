      <to>07 - Unique Rows dedup (fecha, ciudad)</to>
      <enabled>Y</enabled>
    </hop>
    <hop>
      <from>07 - Unique Rows dedup (fecha, ciudad)</from>
      <to>08 - Select Values (columnas finales)</to>
      <enabled>Y</enabled>
    </hop>
    <hop>
      <from>08 - Select Values (columnas finales)</from>
      <to>09 - InsertUpdate staging.observaciones_clean</to>
      <enabled>Y</enabled>
    </hop>
    <hop>
      <from>09 - InsertUpdate staging.observaciones_clean</from>
      <to>10 - Leer staging.observaciones_clean</to>
      <enabled>Y</enabled>
    </hop>
    <hop>
      <from>10 - Leer staging.observaciones_clean</from>
      <to>11 - InsertUpdate olap_snow.dim_clima</to>
      <enabled>Y</enabled>
    </hop>
  </order>
  <step>
    <name>01 - Leer meteo.observaciones_diarias</name>
    <type>TableInput</type>
    <description>Lee datos crudos desde el schema meteo (origen)</description>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <connection>PracticasSM</connection>
    <sql>SELECT
    observacion_id,
    fecha,
    ciudad,
    estacion_id,
    temp_max,
    temp_min,
    temp_media,
    precipitacion_mm,
    humedad_pct,
    velocidad_viento_kmh,
    condicion_climatica
FROM meteo.observaciones_diarias
ORDER BY observacion_id</sql>
    <limit>0</limit>
    <lookup/>
    <execute_each_row>N</execute_each_row>
    <variables_active>N</variables_active>
    <lazy_conversion_active>N</lazy_conversion_active>
    <cached_row_meta_active>N</cached_row_meta_active>
    <row-meta/>
    <attributes/>
    <cluster_schema/>
    <remotesteps>
      <input>
      </input>
      <output>
      </output>
    </remotesteps>
    <GUI>
      <xloc>80</xloc>
      <yloc>200</yloc>
      <draw>Y</draw>
    </GUI>
  </step>
  <step>
    <name>02 - Limpieza JS (A1-A5, A9)</name>
    <type>ScriptValueMod</type>
    <description>Corrige errores de sensor, precipitación negativa, humedad fuera de rango, ciudades inconsistentes, temperaturas invertidas y vocabulario inválido</description>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <compatible>N</compatible>
    <optimizationLevel>9</optimizationLevel>
    <jsScripts>
      <jsScript>
        <jsScript_type>0</jsScript_type>
        <jsScript_name>Script 1</jsScript_name>
        <jsScript_script>// ── A1: Error de sensor -99 → NULL ──────────────────────────
if (temp_max != null &amp;&amp; temp_max == -99.0) temp_max = null;
if (temp_min != null &amp;&amp; temp_min == -99.0) temp_min = null;
if (temp_media != null &amp;&amp; temp_media == -99.0) temp_media = null;

// ── A2: Precipitación negativa → 0.0 ────────────────────────
if (precipitacion_mm != null &amp;&amp; precipitacion_mm &lt; 0) {
    precipitacion_mm = 0.0;
}

// ── A3: Humedad fuera de [0,100] → NULL ─────────────────────
if (humedad_pct != null &amp;&amp; (humedad_pct &lt; 0 || humedad_pct > 100)) {
    humedad_pct = null;
}

// ── A5: Temperaturas invertidas → intercambiar ───────────────
if (temp_min != null &amp;&amp; temp_max != null &amp;&amp; temp_min > temp_max) {
    var t_aux = temp_max;
    temp_max = temp_min;
    temp_min = t_aux;
}

// ── A4: Normalización de ciudades ───────────────────────────
if (ciudad != null) {
    var ciu = ciudad.trim().toLowerCase();
    if      (ciu=='granada'||ciu=='grañada')         { ciudad = 'Granada'; }
    else if (ciu=='sevilla'||ciu=='sevila')           { ciudad = 'Sevilla'; }
    else if (ciu=='málaga'||ciu=='malaga')            { ciudad = 'Málaga'; }
    else if (ciu=='madrid'||ciu=='madríd'||ciu=='madri'){ ciudad = 'Madrid'; }
    else if (ciu=='barcelona'||ciu=='barceloña')     { ciudad = 'Barcelona'; }
    else if (ciu=='valencia'||ciu=='valençia')        { ciudad = 'Valencia'; }
    else if (ciu=='bilbao')                           { ciudad = 'Bilbao'; }
    else if (ciu=='zaragoza')                         { ciudad = 'Zaragoza'; }
    else if (ciu=='alicante'||ciu=='alacant')         { ciudad = 'Alicante'; }
    else if (ciu=='murcia')                           { ciudad = 'Murcia'; }
}

// ── A9: Vocabulario inválido → 'Desconocido' ────────────────
var vocab = ['Soleado','Nublado','Lluvia','Tormenta','Nieve','Niebla','Ventoso','Parcialmente nublado'];
if (condicion_climatica == null || condicion_climatica.trim() == '' || vocab.indexOf(condicion_climatica.trim()) &lt; 0) {
    condicion_climatica = 'Desconocido';
}</jsScript_script>
      </jsScript>
    </jsScripts>
    <fields>
      <field>
        <name>ciudad</name>
        <rename>ciudad</rename>
        <type>String</type>
        <length>80</length>
        <precision>-1</precision>
        <replace>Y</replace>
      </field>
      <field>
        <name>temp_max</name>
        <rename>temp_max</rename>
        <type>Number</type>
        <length>5</length>
        <precision>1</precision>
        <replace>Y</replace>
      </field>
      <field>
        <name>temp_min</name>
        <rename>temp_min</rename>
        <type>Number</type>
        <length>5</length>
        <precision>1</precision>
        <replace>Y</replace>
      </field>
      <field>
        <name>temp_media</name>
        <rename>temp_media</rename>
        <type>Number</type>
        <length>5</length>
        <precision>1</precision>
        <replace>Y</replace>
      </field>
      <field>
        <name>precipitacion_mm</name>
        <rename>precipitacion_mm</rename>
        <type>Number</type>
        <length>6</length>
        <precision>1</precision>
        <replace>Y</replace>
      </field>
      <field>
        <name>humedad_pct</name>
        <rename>humedad_pct</rename>
        <type>Integer</type>
