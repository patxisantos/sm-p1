      <bordercolorred>20</bordercolorred>
      <bordercolorgreen>80</bordercolorgreen>
      <bordercolorblue>20</bordercolorblue>
      <drawshadow>Y</drawshadow>
    </notepad>
  </notepads>
  <order>
    <hop>
      <from>01 - Leer meteo.observaciones_diarias</from>
      <to>02 - Limpieza JS (A1-A5, A9)</to>
      <enabled>Y</enabled>
    </hop>
