  <notepads>
    <notepad>
      <note>FASE 1 – ORIGEN: meteo.*
A1: temp=-99 → NULL
A2: precip&lt;0 → 0.0
A3: humedad>100 → NULL
A4: normalizar ciudades
A5: temp invertidas → swap
A7: filas nulas → descarte
A6: FK huérfanas → log staging
A8: duplicados → dedup
A9: vocab inválido → Desconocido</note>
      <xloc>80</xloc>
      <yloc>50</yloc>
      <width>310</width>
      <heigth>170</heigth>
      <fontname>Arial</fontname>
      <fontsize>10</fontsize>
      <fontbold>N</fontbold>
      <fontitalic>N</fontitalic>
      <fontcolorred>14</fontcolorred>
      <fontcolorgreen>58</fontcolorgreen>
      <fontcolorblue>90</fontcolorblue>
