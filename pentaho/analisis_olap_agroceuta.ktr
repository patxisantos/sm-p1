    <connection>PracticasSM</connection>
    <sql>SELECT
    dp.familia_producto,
    SUM(f.importe_neto)    AS ingresos_reales,
    SUM(f.coste_total)     AS costes_totales,
    SUM(f.margen)          AS margen_total
FROM olap_star.fact_exportaciones f
JOIN olap_star.dim_producto dp ON dp.producto_sk = f.producto_sk
GROUP BY dp.familia_producto
ORDER BY dp.familia_producto</sql>
    <limit>0</limit>
    <lookup/>
    <execute_each_row>N</execute_each_row>
    <variables_active>N</variables_active>
    <lazy_conversion_active>N</lazy_conversion_active>
    <cached_row_meta_active>N</cached_row_meta_active>
    <row-meta>
