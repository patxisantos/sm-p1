        <origin>Entrada Tabla</origin>
        <comments>familia_producto</comments>
        <conversion_Mask/>
        <decimal_symbol>,</decimal_symbol>
        <grouping_symbol>.</grouping_symbol>
        <currency_symbol/>
        <trim_type>none</trim_type>
        <case_insensitive>N</case_insensitive>
